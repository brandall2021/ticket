generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AGENT
  EDITOR
  CLIENT
}

enum TicketStatus {
  NUEVO
  EN_CURSO
  EN_ESPERA
  CERRADO
}

enum Prioridad {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

model User {
  id        String     @id @default(cuid())
  name      String
  apellido  String?
  interno   String?
  cargo     String?
  email     String     @unique
  password  String?
  image     String?
  phone     String?
  role      Role       @default(CLIENT)
  activo    Boolean    @default(true)
  lastLogin DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  assignedTickets Ticket[] @relation("AssignedAgent")
  createdTickets  Ticket[] @relation("Creator")
  comments        Comment[]
  attachments     Attachment[]
  auditLogs       AuditLog[]
  notes           Note[]

  @@index([email])
  @@index([role])
}

model Ticket {
  id          String       @id @default(cuid())
  titulo      String
  descripcion String
  status      TicketStatus @default(NUEVO)
  prioridad   Prioridad    @default(MEDIA)
  ubicacion   String?
  ipPc        String?
  solucion    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  clienteId String
  cliente   User   @relation("Creator", fields: [clienteId], references: [id])

  agenteId  String?
  agente    User?   @relation("AssignedAgent", fields: [agenteId], references: [id])

  categoriaId String?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id])

  comments   Comment[]
  attachments Attachment[]

  @@index([status])
  @@index([prioridad])
  @@index([clienteId])
  @@index([agenteId])
  @@index([categoriaId])
  @@index([createdAt])
}

model Categoria {
  id        String   @id @default(cuid())
  nombre    String   @unique
  color     String   @default("#3b82f6")
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  tickets Ticket[]
}

model Comment {
  id        String   @id @default(cuid())
  contenido String
  createdAt DateTime @default(now())

  ticketId  String
  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  autorId String
  autor   User   @relation(fields: [autorId], references: [id])

  @@index([ticketId])
}

model Attachment {
  id        String   @id @default(cuid())
  nombre    String
  url       String
  createdAt DateTime @default(now())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  subidoPorId String
  subidoPor   User   @relation(fields: [subidoPorId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  accion     String
  detalle    String?
  ip         String?
  fecha      DateTime @default(now())

  usuarioId String
  usuario   User     @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([accion])
  @@index([fecha])
}

model Link {
  id          String   @id @default(cuid())
  title       String
  description String
  url         String
  imageUrl    String
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([title])
}

model Interno {
  id          String   @id @default(cuid())
  asesor      String
  turno       String
  campania    String
  supervision String
  interno     String
  rol         String
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([asesor])
  @@index([interno])
  @@index([campania])
}

model Instructivo {
  id          String   @id @default(cuid())
  title       String
  description String   @default("Instructivo de Gestión")
  url         String
  imageUrl    String
  contenido   String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([title])
}

model StockCategoria {
  id        String      @id @default(cuid())
  nombre    String      @unique
  color     String      @default("#3b82f6")
  icono     String      @default("Package")
  activo    Boolean     @default(true)
  createdAt DateTime    @default(now())

  items     StockItem[]

  @@index([activo])
}

model StockItem {
  id        String   @id @default(cuid())
  nombre    String
  cantidad  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoriaId String
  categoria   StockCategoria @relation(fields: [categoriaId], references: [id])

  @@index([categoriaId])
}

model Note {
  id        String   @id @default(cuid())
  titulo    String
  contenido String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  autorId String
  autor   User   @relation(fields: [autorId], references: [id])

  @@index([autorId])
  @@index([titulo])
  @@index([createdAt])
}
